# Production Environment for SolScore Frontend

# Solana Network (Use mainnet for production)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Backend API URL (Update with your deployed backend URL)
NEXT_PUBLIC_API_URL=https://solscore-api.onrender.com

# Program ID (Update after deploying to mainnet)
NEXT_PUBLIC_PROGRAM_ID=your_deployed_program_id
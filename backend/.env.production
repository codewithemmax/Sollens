# Production Environment Configuration for SolScore

# Helius API
HELIUS_API_KEY=your_production_helius_api_key

# Supabase Database (Replace with your actual Supabase credentials)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Redis (Use Upstash Redis for production)
REDIS_URL=rediss://default:[PASSWORD]@[ENDPOINT]:6380

# Solana Network
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
AUTHORITY_PRIVATE_KEY=your_production_authority_private_key

# Environment
ENVIRONMENT=production

# CORS Origins (Update with your frontend domain)
ALLOWED_ORIGINS=https://your-frontend-domain.com